# ─────────────────────────────────────────────────────────────────
# Agent Backend service environment
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────

# Free key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter-compatible base URL for OpenAI SDK
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model slug. Free tier; falls back to a free Llama or Mistral if Nemotron's tool calling fails.
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Where this service can reach the MCP wrapper
MCP_BASE_URL=http://localhost:4000

# Port this service listens on
AGENT_PORT=4100

# Logging level (debug | info | warn | error)
LOG_LEVEL=info
