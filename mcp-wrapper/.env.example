# ─────────────────────────────────────────────────────────────────
# MCP Wrapper service environment
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────

# Free key from https://api.data.gov/signup/
# Used for: U.S. Department of Education College Scorecard API
SCORECARD_API_KEY=your_api_data_gov_key_here

# Port this service listens on
MCP_WRAPPER_PORT=4000

# Logging level (debug | info | warn | error)
LOG_LEVEL=info
